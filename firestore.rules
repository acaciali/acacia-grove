rules_version = '2';

// Month Money rules.
// History is append-only: undo creates a *new* reversing entry rather than
// editing/deleting an existing one. Chores are fully mutable so we can
// rename, retire (archive), and adjust amounts.
service cloud.firestore {
  match /databases/{database}/documents {
    match /chores/{id} {
      allow read, create, update, delete: if true;
    }

    match /buckets/{id} {
      allow read, create, update, delete: if true;
    }

    match /history/{id} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Aggregated balances (one doc per user+bucket). Written atomically with
    // each history entry; recompute rewrites them from full history.
    match /balances/{id} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    match /groceries/{id} {
      allow read, create, update, delete: if true;
    }

    match /counters/{id} {
      allow read, create, update, delete: if true;
    }

    match /todos/{id} {
      allow read, create, update, delete: if true;
    }
  }
}
